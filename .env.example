# ========================
# PRODUCTION CONFIGURATION GUIDE
# ========================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive credentials!

# ========================
# SECURITY SETTINGS
# ========================
# Generate a secure key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secure-secret-key-here-change-this

# IMPORTANT: Set to 'False' for production! 'True' only for local development
DEBUG=False

# Your production domain(s) - comma-separated (no http://)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-server-ip

# ========================
# DATABASE SETTINGS (PostgreSQL for production)
# ========================
# For development: can use SQLite (modify settings.py)
# For production: PostgreSQL is required
DB_ENGINE=django.db.backends.postgresql
DB_NAME=travel_companion
DB_USER=postgres
DB_PASSWORD=your-super-secure-password-here
DB_HOST=your-db-host.example.com
DB_PORT=5432

# ========================
# CORS SETTINGS (Frontend React)
# ========================
# Your frontend domain(s) - comma-separated with protocol
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://your-frontend-domain.vercel.app

# ========================
# EMAIL CONFIGURATION (Gmail SMTP)
# ========================
# Use Gmail App Password (not your regular password!)
# Generate here: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ========================
# OPTIONAL AWS S3 CONFIG (for media/static files)
# ========================
# Uncomment and fill if using S3:
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
